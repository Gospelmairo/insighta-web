<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Search — Insighta Labs+</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}body{font-family:system-ui,sans-serif;background:#0f172a;color:#e2e8f0}
nav{background:#1e293b;padding:1rem 2rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #334155}
.brand{color:#38bdf8;font-weight:700}.nav-links a{color:#94a3b8;text-decoration:none;margin-left:1.5rem;font-size:.9rem}.nav-links a:hover{color:#38bdf8}
.container{max-width:900px;margin:0 auto;padding:2rem}
h1{font-size:1.5rem;margin-bottom:1.5rem}
.search-box{display:flex;gap:.75rem;margin-bottom:1.5rem}
.search-box input{flex:1;background:#1e293b;border:1px solid #475569;color:#e2e8f0;padding:.75rem 1rem;border-radius:.5rem;font-size:1rem}
.btn{padding:.75rem 1.5rem;border-radius:.5rem;border:none;cursor:pointer;font-size:.9rem;font-weight:600;background:#38bdf8;color:#0f172a}
table{width:100%;border-collapse:collapse;font-size:.875rem}
th{background:#334155;padding:.75rem;text-align:left;color:#94a3b8}
td{padding:.75rem;border-bottom:1px solid #0f172a;color:#cbd5e1}
td a{color:#38bdf8;text-decoration:none}
.error{background:#450a0a;border:1px solid #ef4444;color:#fca5a5;padding:1rem;border-radius:.5rem;margin-bottom:1rem}
.hint{color:#64748b;font-size:.85rem;margin-bottom:1rem}
.total{color:#94a3b8;font-size:.9rem;margin-bottom:1rem}
</style>
</head>
<body>
<nav>
  <span class="brand">Insighta Labs+</span>
  <div class="nav-links">
    <a href="/dashboard">Dashboard</a><a href="/profiles">Profiles</a><a href="/search">Search</a><a href="/account">Account</a>
    <form method="POST" action="/logout" style="display:inline"><button style="background:none;border:none;color:#94a3b8;cursor:pointer;font-size:.9rem;margin-left:1.5rem">Logout</button></form>
  </div>
</nav>
<div class="container">
  <h1>Natural Language Search</h1>
  <form class="search-box" method="GET" action="/search">
    <input name="q" value="<%=q||''%>" placeholder='Try "young males from nigeria" or "adult females from kenya"'>
    <button type="submit" class="btn">Search</button>
  </form>
  <p class="hint">Examples: "seniors from ghana", "females above 30", "teenagers in ethiopia"</p>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <% if (results) { %>
    <p class="total">Found <strong><%= results.total %></strong> results</p>
    <table>
      <thead><tr><th>Name</th><th>Gender</th><th>Age</th><th>Age Group</th><th>Country</th></tr></thead>
      <tbody>
      <% results.data.forEach(p => { %>
      <tr>
        <td><a href="/profiles/<%=p.id%>"><%=p.name%></a></td>
        <td><%=p.gender%></td><td><%=p.age%></td><td><%=p.age_group%></td>
        <td><%=p.country_id%> — <%=p.country_name%></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
</body>
</html>
