<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Profiles — Insighta Labs+</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}body{font-family:system-ui,sans-serif;background:#0f172a;color:#e2e8f0}
nav{background:#1e293b;padding:1rem 2rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #334155}
.brand{color:#38bdf8;font-weight:700}.nav-links a{color:#94a3b8;text-decoration:none;margin-left:1.5rem;font-size:.9rem}.nav-links a:hover{color:#38bdf8}
.container{max-width:1200px;margin:0 auto;padding:2rem}
h1{font-size:1.5rem;margin-bottom:1rem}
.filters{background:#1e293b;border:1px solid #334155;border-radius:.75rem;padding:1.25rem;margin-bottom:1.5rem;display:flex;gap:.75rem;flex-wrap:wrap;align-items:flex-end}
.filters label{display:flex;flex-direction:column;gap:.3rem;font-size:.8rem;color:#94a3b8}
input,select{background:#334155;border:1px solid #475569;color:#e2e8f0;padding:.4rem .6rem;border-radius:.375rem;font-size:.85rem}
.btn{padding:.5rem 1rem;border-radius:.5rem;border:none;cursor:pointer;font-size:.85rem;font-weight:600}
.btn-primary{background:#38bdf8;color:#0f172a}.btn-secondary{background:#334155;color:#e2e8f0;text-decoration:none}
table{width:100%;border-collapse:collapse;font-size:.875rem}
th{background:#334155;padding:.75rem;text-align:left;color:#94a3b8}
td{padding:.75rem;border-bottom:1px solid #0f172a;color:#cbd5e1}
td a{color:#38bdf8;text-decoration:none}tr:hover td{background:#1e293b}
.pagination{display:flex;gap:.5rem;margin-top:1rem}
.pagination a{padding:.4rem .8rem;background:#334155;border-radius:.375rem;color:#e2e8f0;text-decoration:none;font-size:.85rem}
.pagination a:hover,.pagination .active{background:#38bdf8;color:#0f172a}
.error{background:#450a0a;border:1px solid #ef4444;color:#fca5a5;padding:1rem;border-radius:.5rem;margin-bottom:1rem}
</style>
</head>
<body>
<nav>
  <span class="brand">Insighta Labs+</span>
  <div class="nav-links">
    <a href="/dashboard">Dashboard</a><a href="/profiles">Profiles</a><a href="/search">Search</a><a href="/account">Account</a>
    <form method="POST" action="/logout" style="display:inline"><button style="background:none;border:none;color:#94a3b8;cursor:pointer;font-size:.9rem;margin-left:1.5rem">Logout</button></form>
  </div>
</nav>
<div class="container">
  <h1>Profiles <span style="color:#94a3b8;font-size:1rem;font-weight:400">(<%= data.total %> total)</span></h1>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <form class="filters" method="GET" action="/profiles">
    <label>Gender<select name="gender"><option value="">All</option><option value="male" <%=query.gender==='male'?'selected':''%>>Male</option><option value="female" <%=query.gender==='female'?'selected':''%>>Female</option></select></label>
    <label>Age Group<select name="age_group"><option value="">All</option><option value="child">Child</option><option value="teenager">Teenager</option><option value="adult">Adult</option><option value="senior">Senior</option></select></label>
    <label>Country ID<input name="country_id" value="<%=query.country_id||''%>" placeholder="e.g. NG" style="width:80px"></label>
    <label>Sort By<select name="sort_by"><option value="created_at">Created</option><option value="age">Age</option><option value="gender_probability">Confidence</option></select></label>
    <label>Order<select name="order"><option value="asc">Asc</option><option value="desc">Desc</option></select></label>
    <label>Limit<select name="limit"><option value="10">10</option><option value="25">25</option><option value="50">50</option></select></label>
    <button type="submit" class="btn btn-primary">Filter</button>
    <a href="/profiles" class="btn btn-secondary">Reset</a>
  </form>
  <table>
    <thead><tr><th>Name</th><th>Gender</th><th>Age</th><th>Age Group</th><th>Country</th><th>Confidence</th><th>Created</th></tr></thead>
    <tbody>
    <% data.data.forEach(p => { %>
    <tr>
      <td><a href="/profiles/<%=p.id%>"><%=p.name%></a></td>
      <td><%=p.gender%></td><td><%=p.age%></td><td><%=p.age_group%></td>
      <td><%=p.country_id%> — <%=p.country_name%></td>
      <td><%=Math.round(p.gender_probability*100)%>%</td>
      <td><%=p.created_at?.slice(0,10)%></td>
    </tr>
    <% }) %>
    </tbody>
  </table>
  <div class="pagination">
    <% if (data.page > 1) { %><a href="/profiles?<%=new URLSearchParams({...query,page:data.page-1})%>">← Prev</a><% } %>
    <span style="padding:.4rem .8rem;color:#94a3b8">Page <%=data.page%> of <%=data.total_pages%></span>
    <% if (data.page < data.total_pages) { %><a href="/profiles?<%=new URLSearchParams({...query,page:data.page+1})%>">Next →</a><% } %>
  </div>
</div>
</body>
</html>
