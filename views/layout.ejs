<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Insighta Labs+</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;background:#0f172a;color:#e2e8f0;min-height:100vh}
nav{background:#1e293b;padding:1rem 2rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #334155}
nav a{color:#94a3b8;text-decoration:none;margin-left:1.5rem;font-size:.9rem}
nav a:hover{color:#38bdf8}
nav .brand{color:#38bdf8;font-weight:700;font-size:1.1rem;margin:0}
.container{max-width:1200px;margin:0 auto;padding:2rem}
.card{background:#1e293b;border-radius:.75rem;padding:1.5rem;border:1px solid #334155;margin-bottom:1rem}
.btn{display:inline-block;padding:.5rem 1.25rem;border-radius:.5rem;border:none;cursor:pointer;font-size:.9rem;text-decoration:none}
.btn-primary{background:#38bdf8;color:#0f172a;font-weight:600}
.btn-primary:hover{background:#0ea5e9}
.btn-danger{background:#ef4444;color:#fff}
table{width:100%;border-collapse:collapse;font-size:.875rem}
th{background:#334155;padding:.75rem;text-align:left;color:#94a3b8}
td{padding:.75rem;border-bottom:1px solid #1e293b;color:#cbd5e1}
tr:hover td{background:#1e293b}
input,select{background:#334155;border:1px solid #475569;color:#e2e8f0;padding:.5rem .75rem;border-radius:.375rem;font-size:.875rem}
.badge{display:inline-block;padding:.25rem .6rem;border-radius:999px;font-size:.75rem;font-weight:600}
.badge-admin{background:#7c3aed;color:#fff}
.badge-analyst{background:#0891b2;color:#fff}
.error{background:#450a0a;border:1px solid #ef4444;color:#fca5a5;padding:1rem;border-radius:.5rem;margin-bottom:1rem}
.stat{text-align:center;padding:1.5rem}
.stat .num{font-size:2.5rem;font-weight:700;color:#38bdf8}
.stat .label{color:#94a3b8;font-size:.875rem;margin-top:.25rem}
.pagination{display:flex;gap:.5rem;margin-top:1rem;align-items:center}
.pagination a{padding:.4rem .8rem;background:#334155;border-radius:.375rem;color:#e2e8f0;text-decoration:none;font-size:.875rem}
.pagination a:hover{background:#475569}
.pagination .active{background:#38bdf8;color:#0f172a}
</style>
</head>
<body>
<%- body %>
</body>
</html>
