<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Profile — Insighta Labs+</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}body{font-family:system-ui,sans-serif;background:#0f172a;color:#e2e8f0}
nav{background:#1e293b;padding:1rem 2rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #334155}
.brand{color:#38bdf8;font-weight:700}.nav-links a{color:#94a3b8;text-decoration:none;margin-left:1.5rem;font-size:.9rem}.nav-links a:hover{color:#38bdf8}
.container{max-width:800px;margin:0 auto;padding:2rem}
.card{background:#1e293b;border:1px solid #334155;border-radius:.75rem;padding:2rem}
h1{font-size:1.5rem;margin-bottom:1.5rem;text-transform:capitalize}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.field{padding:.75rem;background:#0f172a;border-radius:.5rem}
.field .key{font-size:.75rem;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.25rem}
.field .val{font-size:1rem;color:#e2e8f0}
.back{display:inline-block;margin-bottom:1rem;color:#38bdf8;text-decoration:none;font-size:.9rem}
.error{background:#450a0a;border:1px solid #ef4444;color:#fca5a5;padding:1rem;border-radius:.5rem}
</style>
</head>
<body>
<nav>
  <span class="brand">Insighta Labs+</span>
  <div class="nav-links">
    <a href="/dashboard">Dashboard</a><a href="/profiles">Profiles</a><a href="/search">Search</a><a href="/account">Account</a>
    <form method="POST" action="/logout" style="display:inline"><button style="background:none;border:none;color:#94a3b8;cursor:pointer;font-size:.9rem;margin-left:1.5rem">Logout</button></form>
  </div>
</nav>
<div class="container">
  <a href="/profiles" class="back">← Back to Profiles</a>
  <% if (error) { %><div class="error"><%= error %></div>
  <% } else { %>
  <div class="card">
    <h1><%= profile.name %></h1>
    <div class="grid">
      <div class="field"><div class="key">ID</div><div class="val" style="font-size:.75rem;word-break:break-all"><%= profile.id %></div></div>
      <div class="field"><div class="key">Gender</div><div class="val"><%= profile.gender %> (<%= Math.round(profile.gender_probability*100) %>%)</div></div>
      <div class="field"><div class="key">Age</div><div class="val"><%= profile.age %></div></div>
      <div class="field"><div class="key">Age Group</div><div class="val"><%= profile.age_group %></div></div>
      <div class="field"><div class="key">Country</div><div class="val"><%= profile.country_id %> — <%= profile.country_name %></div></div>
      <div class="field"><div class="key">Country Probability</div><div class="val"><%= Math.round(profile.country_probability*100) %>%</div></div>
      <div class="field"><div class="key">Created At</div><div class="val"><%= profile.created_at %></div></div>
    </div>
  </div>
  <% } %>
</div>
</body>
</html>
